@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard";
    string userName = ViewBag.UserName ?? "Admin";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0F172A;
            color: #FFFFFF;
            display: flex;
            min-height: 100vh;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: 280px;
            background: linear-gradient(180deg, #0F172A 0%, #1E293B 100%);
            border-right: 1px solid #334155;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 28px 24px;
            border-bottom: 1px solid #334155;
        }

        .sidebar-brand .brand-icon {
            font-size: 32px;
            margin-bottom: 8px;
            color: #3B82F6;
        }

        .sidebar-brand h2 {
            font-size: 18px;
            font-weight: 700;
            color: #FFFFFF;
        }

        .sidebar-brand span {
            color: #3B82F6;
            font-size: 12px;
        }

        .sidebar-nav {
            padding: 20px 0;
            flex: 1;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 24px;
            margin: 4px 12px;
            border-radius: 10px;
            color: #94A3B8;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
            cursor: pointer;
        }

        .nav-item:hover {
            color: #FFFFFF;
            background: #334155;
        }

        .nav-item.active {
            color: #3B82F6;
            background: rgba(59, 130, 246, 0.1);
        }

        .nav-item i {
            width: 20px;
        }

        .sidebar-footer {
            padding: 20px 24px;
            border-top: 1px solid #334155;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #94A3B8;
            text-decoration: none;
            font-size: 13px;
        }

        .logout-btn:hover {
            color: #EF4444;
        }

        /* ===== MAIN CONTENT ===== */
        .main-content {
            margin-left: 280px;
            flex: 1;
            padding: 0;
        }

        /* ===== TOPBAR ===== */
        .topbar {
            background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
            padding: 20px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid #334155;
        }

        .welcome-text h1 {
            font-size: 24px;
            font-weight: 700;
        }

        .welcome-text h1 span {
            color: #3B82F6;
        }

        .welcome-text p {
            font-size: 14px;
            color: #94A3B8;
            margin-top: 4px;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255, 255, 255, 0.05);
            padding: 8px 20px;
            border-radius: 40px;
        }

        .user-profile i {
            color: #3B82F6;
        }

        /* ===== CONTENT AREA ===== */
        .content-area {
            padding: 32px;
        }

        /* ===== STATS CARDS ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 32px;
        }

        .stat-card {
            background: #1E293B;
            border: 1px solid #334155;
            border-radius: 16px;
            padding: 20px;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: #3B82F6;
        }

        .stat-card:hover {
            transform: translateY(-4px);
            border-color: #3B82F6;
        }

        .stat-card .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .stat-card .stat-header span {
            font-size: 13px;
            color: #94A3B8;
        }

        .stat-card .stat-icon {
            width: 48px;
            height: 48px;
            background: rgba(59, 130, 246, 0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: #3B82F6;
        }

        .stat-card h2 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .stat-card p {
            font-size: 13px;
            color: #94A3B8;
        }

        .trend-up { color: #22C55E; }
        .trend-down { color: #EF4444; }

        /* ===== CHARTS SECTION ===== */
        .charts-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 32px;
        }

        .chart-card {
            background: #1E293B;
            border: 1px solid #334155;
            border-radius: 16px;
            padding: 20px;
        }

        .chart-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #FFFFFF;
        }

        .chart-title i {
            color: #3B82F6;
        }

        canvas {
            max-height: 250px;
            width: 100%;
        }

        /* ===== TABLES ===== */
        .table-container {
            background: #1E293B;
            border: 1px solid #334155;
            border-radius: 16px;
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: #0F172A;
        }

        thead th {
            padding: 16px 20px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            color: #94A3B8;
            text-transform: uppercase;
        }

        tbody tr {
            border-top: 1px solid #334155;
        }

        tbody tr:hover {
            background: #334155;
        }

        tbody td {
            padding: 16px 20px;
            font-size: 14px;
        }

        .badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-critical { background: rgba(239,68,68,0.15); color: #EF4444; }
        .badge-high { background: rgba(245,158,11,0.15); color: #F59E0B; }
        .badge-medium { background: rgba(234,179,8,0.15); color: #EAB308; }
        .badge-low { background: rgba(34,197,94,0.15); color: #22C55E; }

        .status-open { background: rgba(59,130,246,0.15); color: #3B82F6; padding: 4px 12px; border-radius: 20px; display: inline-block; }
        .status-inprogress { background: rgba(245,158,11,0.15); color: #F59E0B; padding: 4px 12px; border-radius: 20px; display: inline-block; }
        .status-resolved { background: rgba(34,197,94,0.15); color: #22C55E; padding: 4px 12px; border-radius: 20px; display: inline-block; }

        .btn-view {
            background: #334155;
            color: #3B82F6;
            padding: 6px 14px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 12px;
        }

        .btn-view:hover {
            background: #3B82F6;
            color: white;
        }

        .btn-primary {
            background: #3B82F6;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            cursor: pointer;
        }

        .empty-state {
            text-align: center;
            padding: 60px;
            color: #94A3B8;
        }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 16px;
            display: block;
        }

        /* Operator Table Actions */
        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .btn-edit, .btn-delete {
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 12px;
            cursor: pointer;
            border: none;
        }

        .btn-edit {
            background: #3B82F6;
            color: white;
        }

        .btn-delete {
            background: #EF4444;
            color: white;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: #1E293B;
            border-radius: 16px;
            padding: 32px;
            width: 500px;
            max-width: 90%;
        }

        .modal-content input, .modal-content select {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            background: #0F172A;
            border: 1px solid #334155;
            color: white;
            border-radius: 8px;
        }

        .modal-buttons {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .hide {
            display: none;
        }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-icon">🚨</div>
        <h2>SMART CIVIC</h2>
        <span>ALERT SYSTEM</span>
    </div>
    <nav class="sidebar-nav">
        <a class="nav-item active" onclick="showSection('dashboard')">
            <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
        <a class="nav-item" onclick="showSection('incidents')">
            <i class="fas fa-list-alt"></i> Incidents
        </a>
        <a class="nav-item" onclick="showSection('operators')">
            <i class="fas fa-users"></i> Operators
        </a>
        <a class="nav-item" onclick="showSection('analytics')">
            <i class="fas fa-chart-line"></i> Analytics
        </a>
        <a class="nav-item" onclick="showSection('reports')">
            <i class="fas fa-file-alt"></i> Reports
        </a>
    </nav>
    <div class="sidebar-footer">
        <a href="/Account/Logout" class="logout-btn">
            <i class="fas fa-sign-out-alt"></i> Logout
        </a>
    </div>
</aside>

<div class="main-content">
    <div class="topbar">
        <div class="welcome-text">
            <h1>Welcome, <span>@userName</span>! 👋</h1>
            <p>Admin Dashboard — Manage your city's incident response system</p>
        </div>
        <div class="user-profile">
            <i class="fas fa-user-shield"></i>
            <span>@userName</span>
        </div>
    </div>

    <div class="content-area">
        <!-- ==================== DASHBOARD SECTION ==================== -->
        <div id="dashboardSection">
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-header">
                        <span>Total Today</span>
                        <div class="stat-icon"><i class="fas fa-calendar-day"></i></div>
                    </div>
                    <h2 id="totalToday">@ViewBag.TotalToday</h2>
                    <p>Incidents reported today</p>
                </div>
                <div class="stat-card">
                    <div class="stat-header">
                        <span>Resolved Today</span>
                        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                    </div>
                    <h2 id="resolvedToday">@ViewBag.ResolvedToday</h2>
                    <p>Successfully resolved</p>
                </div>
                <div class="stat-card">
                    <div class="stat-header">
                        <span>Critical Open</span>
                        <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
                    </div>
                    <h2 id="criticalIncidents">@ViewBag.CriticalIncidents</h2>
                    <p>Critical incidents pending</p>
                </div>
                <div class="stat-card">
                    <div class="stat-header">
                        <span>Pending Incidents</span>
                        <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
                    </div>
                    <h2 id="pendingIncidents">@ViewBag.PendingIncidents</h2>
                    <p>Open or in progress</p>
                </div>
            </div>

            <div class="charts-section">
                <div class="chart-card">
                    <div class="chart-title"><i class="fas fa-chart-line"></i> Last 7 Days Trend</div>
                    <canvas id="trendChart"></canvas>
                </div>
                <div class="chart-card">
                    <div class="chart-title"><i class="fas fa-chart-pie"></i> Severity Distribution</div>
                    <canvas id="severityChart"></canvas>
                </div>
            </div>

            <div class="section-header" style="display: flex; justify-content: space-between; margin-bottom: 20px;">
                <h2><i class="fas fa-clock"></i> Recent Incidents</h2>
                <button class="btn-primary" onclick="showSection('incidents')">View All →</button>
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr><th>Title</th><th>Location</th><th>Severity</th><th>Status</th><th>Reported At</th><th>Action</th></tr>
                    </thead>
                    <tbody id="recentIncidentsTable">
                        @if (ViewBag.RecentIncidents != null)
                        {
                            @foreach (var incident in ViewBag.RecentIncidents)
                            {
                                <tr>
                                    <td><strong>@incident.Title</strong></td>
                                    <td>@incident.Location</td>
                                    <td><span class="badge badge-@incident.Severity.ToLower()">@incident.Severity</span></td>
                                    <td><span class="status-@incident.Status.ToLower().Replace(" ", "")">@incident.Status</span></td>
                                    <td>@incident.ReportedAt.ToString("dd MMM yyyy, hh:mm tt")</td>
                                    <td><a href="/Admin/IncidentDetail/@incident.Id" class="btn-view">View</a></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ==================== INCIDENTS SECTION ==================== -->
        <div id="incidentsSection" class="hide">
            <h2><i class="fas fa-list-alt"></i> All Incidents</h2>
            <div class="filter-bar" style="margin: 20px 0; display: flex; gap: 12px;">
                <select id="statusFilter">
                    <option value="">All Status</option>
                    <option value="Open">Open</option>
                    <option value="In Progress">In Progress</option>
                    <option value="Resolved">Resolved</option>
                </select>
                <select id="severityFilter">
                    <option value="">All Severity</option>
                    <option value="Critical">Critical</option>
                    <option value="High">High</option>
                    <option value="Medium">Medium</option>
                    <option value="Low">Low</option>
                </select>
                <button class="btn-primary" onclick="loadAllIncidents()">Filter</button>
            </div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr><th>Title</th><th>Location</th><th>Department</th><th>Severity</th><th>Status</th><th>Reported At</th><th>Action</th></tr>
                    </thead>
                    <tbody id="allIncidentsTable"></tbody>
                </table>
            </div>
        </div>

        <!-- ==================== OPERATORS SECTION ==================== -->
        <div id="operatorsSection" class="hide">
            <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
                <h2><i class="fas fa-users"></i> Operators Management</h2>
                <button class="btn-primary" onclick="openAddOperatorModal()">+ Add Operator</button>
            </div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr><th>Name</th><th>Email</th><th>Phone</th><th>Department</th><th>Actions</th></tr>
                    </thead>
                    <tbody id="operatorsTable"></tbody>
                </table>
            </div>
        </div>

        <!-- ==================== ANALYTICS SECTION ==================== -->
        <div id="analyticsSection" class="hide">
            <h2><i class="fas fa-chart-line"></i> Analytics Dashboard</h2>
            <div class="charts-section">
                <div class="chart-card">
                    <div class="chart-title"><i class="fas fa-building"></i> Department-wise Incidents</div>
                    <canvas id="deptChart"></canvas>
                </div>
                <div class="chart-card">
                    <div class="chart-title"><i class="fas fa-chart-bar"></i> Severity Overview</div>
                    <canvas id="analyticsSeverityChart"></canvas>
                </div>
            </div>
            <div class="chart-card" style="margin-top: 20px;">
                <div class="chart-title"><i class="fas fa-chart-line"></i> Weekly Trend (Total vs Resolved)</div>
                <canvas id="trendDetailChart"></canvas>
            </div>
        </div>

        <!-- ==================== REPORTS SECTION ==================== -->
        <div id="reportsSection" class="hide">
            <h2><i class="fas fa-file-alt"></i> Generate Reports</h2>
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 20px;">
                <div class="chart-card" style="text-align: center;">
                    <i class="fas fa-calendar-week" style="font-size: 48px; color: #3B82F6;"></i>
                    <h3 style="margin: 15px 0;">Weekly Report</h3>
                    <p>Last 7 days incident summary</p>
                    <button class="btn-primary" onclick="generateReport('weekly')" style="margin-top: 15px;">Download PDF</button>
                </div>
                <div class="chart-card" style="text-align: center;">
                    <i class="fas fa-calendar-month" style="font-size: 48px; color: #3B82F6;"></i>
                    <h3 style="margin: 15px 0;">Monthly Report</h3>
                    <p>Last 30 days incident summary</p>
                    <button class="btn-primary" onclick="generateReport('monthly')" style="margin-top: 15px;">Download PDF</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Operator Modal -->
<div id="operatorModal" class="modal">
    <div class="modal-content">
        <h3 id="modalTitle">Add New Operator</h3>
        <input type="hidden" id="operatorId" />
        <input type="text" id="opName" placeholder="Full Name" />
        <input type="email" id="opEmail" placeholder="Email" />
        <input type="text" id="opPhone" placeholder="Phone" />
        <select id="opDepartment">
            <option value="">Select Department</option>
            <option value="Fire">Fire Department</option>
            <option value="Police">Police Department</option>
            <option value="Rescue">Rescue Department</option>
        </select>
        <input type="password" id="opPassword" placeholder="Password" />
        <div class="modal-buttons">
            <button class="btn-primary" onclick="saveOperator()">Save</button>
            <button class="btn-delete" onclick="closeModal()">Cancel</button>
        </div>
    </div>
</div>

<script>
    // Section Navigation
    function showSection(section) {
        document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
        event.target.classList.add('active');
        
        document.getElementById('dashboardSection').classList.add('hide');
        document.getElementById('incidentsSection').classList.add('hide');
        document.getElementById('operatorsSection').classList.add('hide');
        document.getElementById('analyticsSection').classList.add('hide');
        document.getElementById('reportsSection').classList.add('hide');
        
        document.getElementById(section + 'Section').classList.remove('hide');
        
        if (section === 'incidents') loadAllIncidents();
        if (section === 'operators') loadOperators();
        if (section === 'analytics') loadAnalytics();
    }

    // Load All Incidents
    async function loadAllIncidents() {
        const status = document.getElementById('statusFilter').value;
        const severity = document.getElementById('severityFilter').value;
        
        let url = '/Admin/GetAllIncidentsJson';
        if (status || severity) {
            url += `?status=${status}&severity=${severity}`;
        }
        
        const response = await fetch(url);
        const incidents = await response.json();
        
        const tbody = document.getElementById('allIncidentsTable');
        tbody.innerHTML = '';
        
        if (incidents.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="empty-state">No incidents found</td></tr>';
            return;
        }
        
        incidents.forEach(i => {
            const row = tbody.insertRow();
            row.innerHTML = `
                <td><strong>${i.title}</strong></td>
                <td>${i.location}</td>
                <td>${i.department || '-'}</td>
                <td><span class="badge badge-${i.severity?.toLowerCase()}">${i.severity}</span></td>
                <td><span class="status-${i.status?.toLowerCase().replace(' ', '')}">${i.status}</span></td>
                <td>${new Date(i.reportedAt).toLocaleString()}</td>
                <td><a href="/Admin/IncidentDetail/${i.id}" class="btn-view">View</a></td>
            `;
        });
    }

    // Load Operators
    async function loadOperators() {
        const response = await fetch('/Admin/GetOperatorsJson');
        const operators = await response.json();
        
        const tbody = document.getElementById('operatorsTable');
        tbody.innerHTML = '';
        
        operators.forEach(op => {
            const row = tbody.insertRow();
            row.innerHTML = `
                <td>${op.name}</td>
                <td>${op.email}</td>
                <td>${op.phone || '-'}</td>
                <td>${op.department || '-'}</td>
                <td class="action-buttons">
                    <button class="btn-edit" onclick="editOperator('${op.id}', '${op.name}', '${op.email}', '${op.phone || ''}', '${op.department || ''}')">Edit</button>
                    <button class="btn-delete" onclick="deleteOperator('${op.id}')">Delete</button>
                </td>
            `;
        });
    }

    // Open Add Operator Modal
    function openAddOperatorModal() {
        document.getElementById('modalTitle').innerText = 'Add New Operator';
        document.getElementById('operatorId').value = '';
        document.getElementById('opName').value = '';
        document.getElementById('opEmail').value = '';
        document.getElementById('opPhone').value = '';
        document.getElementById('opDepartment').value = '';
        document.getElementById('opPassword').value = '';
        document.getElementById('operatorModal').style.display = 'flex';
    }

    // Edit Operator
    function editOperator(id, name, email, phone, department) {
        document.getElementById('modalTitle').innerText = 'Edit Operator';
        document.getElementById('operatorId').value = id;
        document.getElementById('opName').value = name;
        document.getElementById('opEmail').value = email;
        document.getElementById('opPhone').value = phone;
        document.getElementById('opDepartment').value = department;
        document.getElementById('opPassword').value = '';
        document.getElementById('operatorModal').style.display = 'flex';
    }

    // Save Operator
    async function saveOperator() {
        const id = document.getElementById('operatorId').value;
        const data = {
            id: id,
            name: document.getElementById('opName').value,
            email: document.getElementById('opEmail').value,
            phone: document.getElementById('opPhone').value,
            department: document.getElementById('opDepartment').value,
            passwordHash: document.getElementById('opPassword').value
        };
        
        const url = id ? '/Admin/UpdateOperator' : '/Admin/CreateOperator';
        const response = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        alert(result.message);
        closeModal();
        loadOperators();
    }

    // Delete Operator
    async function deleteOperator(id) {
        if (!confirm('Are you sure?')) return;
        const response = await fetch('/Admin/DeleteOperator', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: id })
        });
        const result = await response.json();
        alert(result.message);
        loadOperators();
    }

    // Close Modal
    function closeModal() {
        document.getElementById('operatorModal').style.display = 'none';
    }

    // Load Analytics
    async function loadAnalytics() {
        const response = await fetch('/Admin/GetAnalyticsJson');
        const data = await response.json();
        
        // Department Chart
        const deptLabels = data.departments.map(d => d.department);
        const deptCounts = data.departments.map(d => d.count);
        new Chart(document.getElementById('deptChart'), {
            type: 'doughnut',
            data: { labels: deptLabels, datasets: [{ data: deptCounts, backgroundColor: ['#EF4444', '#3B82F6', '#22C55E'] }] }
        });
        
        // Severity Chart
        new Chart(document.getElementById('analyticsSeverityChart'), {
            type: 'bar',
            data: { labels: ['Critical', 'High', 'Medium', 'Low'], datasets: [{ label: 'Count', data: [data.severity.critical, data.severity.high, data.severity.medium, data.severity.low], backgroundColor: '#3B82F6' }] }
        });
        
        // Trend Chart
        const trendLabels = data.trend.map(t => t.date);
        const totalData = data.trend.map(t => t.total);
        const resolvedData = data.trend.map(t => t.resolved);
        new Chart(document.getElementById('trendDetailChart'), {
            type: 'line',
            data: { labels: trendLabels, datasets: [{ label: 'Total', data: totalData, borderColor: '#3B82F6' }, { label: 'Resolved', data: resolvedData, borderColor: '#22C55E' }] }
        });
    }

    // Generate Report
    function generateReport(type) {
        alert(`${type.toUpperCase()} report generation feature coming soon!`);
    }

    // Initial Load
    document.getElementById('dashboardSection').classList.remove('hide');
    
    // Dashboard Charts
    fetch('/Admin/GetAnalyticsJson').then(r => r.json()).then(data => {
        new Chart(document.getElementById('trendChart'), {
            type: 'line',
            data: { labels: data.trend.map(t => t.date), datasets: [{ label: 'Incidents', data: data.trend.map(t => t.total), borderColor: '#3B82F6', fill: false }] }
        });
        new Chart(document.getElementById('severityChart'), {
            type: 'doughnut',
            data: { labels: ['Critical', 'High', 'Medium', 'Low'], datasets: [{ data: [data.severity.critical, data.severity.high, data.severity.medium, data.severity.low], backgroundColor: ['#EF4444', '#F59E0B', '#EAB308', '#22C55E'] }] }
        });
    });
</script>

</body>
</html>