@{
    Layout = null;
    ViewData["Title"] = "Login - Smart Civic Alert";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0F172A 0%, #1E293B 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* Simple Navbar */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background-color: #1E293B;
            border-bottom: 2px solid #3B82F6;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar-brand {
            color: #FFFFFF;
            font-size: 1.25rem;
            font-weight: bold;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .navbar-brand i {
                color: #3B82F6;
            }

            .navbar-brand span {
                color: #3B82F6;
            }

        .nav-links a {
            color: #94A3B8;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .login-container {
            width: 100%;
            max-width: 450px;
            padding: 2rem;
            margin-top: 80px;
        }

        .login-card {
            background-color: #1E293B;
            border: 1px solid #334155;
            border-radius: 24px;
            padding: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .logo {
            text-align: center;
            margin-bottom: 2rem;
        }

            .logo i {
                font-size: 3rem;
                color: #3B82F6;
                margin-bottom: 0.5rem;
            }

            .logo h2 {
                color: white;
                font-size: 1.5rem;
            }

            .logo span {
                color: #3B82F6;
            }

        .input-group {
            margin-bottom: 1.5rem;
        }

            .input-group label {
                display: block;
                color: #94A3B8;
                font-size: 0.875rem;
                margin-bottom: 0.5rem;
            }

        .input-wrapper {
            position: relative;
        }

            .input-wrapper i {
                position: absolute;
                left: 1rem;
                top: 50%;
                transform: translateY(-50%);
                color: #64748B;
            }

        .input-group input {
            width: 100%;
            padding: 0.75rem 1rem 0.75rem 2.5rem;
            background-color: #0F172A;
            border: 1px solid #334155;
            border-radius: 12px;
            color: white;
            font-size: 1rem;
        }

            .input-group input:focus {
                outline: none;
                border-color: #3B82F6;
            }

        .btn-login {
            width: 100%;
            padding: 0.875rem;
            background-color: #3B82F6;
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
        }

            .btn-login:hover {
                background-color: #2563EB;
                transform: translateY(-1px);
            }

        .forgot-link {
            text-align: right;
            margin: 0.5rem 0 1.5rem;
        }

            .forgot-link a {
                color: #3B82F6;
                text-decoration: none;
                font-size: 0.875rem;
            }

        .register-link {
            text-align: center;
            color: #94A3B8;
            font-size: 0.875rem;
            margin-top: 1.5rem;
        }

            .register-link a {
                color: #3B82F6;
                text-decoration: none;
            }

        .alert-error {
            background-color: #7F1D1D;
            color: #FECACA;
            padding: 0.75rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            border-left: 4px solid #EF4444;
        }

        .alert-success {
            background-color: #14532D;
            color: #BBF7D0;
            padding: 0.75rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            border-left: 4px solid #22C55E;
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <a href="/" class="navbar-brand">
            <i class="fas fa-city"></i> SMART CIVIC <span>ALERT</span>
        </a>
        <div class="nav-links">
            <a href="/Account/Register"><i class="fas fa-user-plus"></i> Register</a>
        </div>
    </nav>

    <div class="login-container">
        <div class="login-card">
            <div class="logo">
                <i class="fas fa-city"></i>
                <h2>Welcome <span>Back!</span></h2>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert-success">@TempData["SuccessMessage"]</div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="alert-error">@ViewBag.Error</div>
            }

            <form method="post" action="/Account/Login">
                <div class="input-group">
                    <label>Email Address</label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope"></i>
                        <input type="email" name="email" placeholder="Enter your email" required>
                    </div>
                </div>

                <div class="input-group">
                    <label>Password</label>
                    <div class="input-wrapper">
                        <i class="fas fa-lock"></i>
                        <input type="password" name="password" placeholder="Enter your password" required>
                    </div>
                </div>

                <div class="forgot-link">
                    <a href="#">Forgot Password?</a>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </button>

                <div class="register-link">
                    Don't have an account? <a href="/Account/Register">Register here</a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>