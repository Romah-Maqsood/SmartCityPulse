@model SmartCityPulse.Models.Incident
@{
    ViewData["Title"] = "Create Incident";
    Layout = null;
    string operatorName = ViewBag.OperatorName ?? "";
    string dept = ViewBag.Department ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Incident</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/site.css" />
    <style>
        .main-content { margin-left: 280px; flex: 1; }
        .content-area { padding: 32px; max-width: 800px; }
        .card { background: #1E293B; border: 1px solid #334155; border-radius: 16px; padding: 32px; }
        .card-title { font-size: 18px; font-weight: 700; margin-bottom: 28px; display: flex; align-items: center; gap: 10px; }
        .card-title i { color: #3B82F6; }
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .form-group.full { grid-column: 1 / -1; }
        .form-group label { display: block; font-size: 13px; color: #94A3B8; margin-bottom: 8px; }
        input, select, textarea {
            width: 100%;
            background: #0F172A;
            border: 1px solid #334155;
            color: #FFFFFF;
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 14px;
        }
        input:focus, select:focus, textarea:focus { outline: none; border-color: #3B82F6; }
        .btn-submit { background: #3B82F6; color: #fff; border: none; padding: 12px 32px; border-radius: 10px; font-size: 15px; font-weight: 600; cursor: pointer; }
        .btn-submit:hover { background: #2563EB; }
        .btn-cancel { background: #334155; color: #94A3B8; border: none; padding: 12px 24px; border-radius: 10px; text-decoration: none; }
        .btn-cancel:hover { background: #475569; color: #fff; }
        .form-actions { display: flex; gap: 12px; margin-top: 28px; }
        @@media (max-width: 768px) { .main-content { margin-left: 80px; } }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-brand"><div class="brand-icon">🚨</div><h2>SMART CIVIC</h2><span>ALERT SYSTEM</span></div>
    <nav class="sidebar-nav">
        <a href="/Operator/Dashboard" class="nav-item"><i class="fas fa-tachometer-alt"></i> <span>Dashboard</span></a>
        <a href="/Operator/Incidents" class="nav-item"><i class="fas fa-list-alt"></i> <span>Incidents</span></a>
        <a href="/Operator/CreateIncident" class="nav-item active"><i class="fas fa-plus-circle"></i> <span>Create Incident</span></a>
    </nav>
    <div class="sidebar-footer">
        <div class="dept-badge"><i class="fas fa-building"></i> @dept Department</div>
        <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> <span>Logout</span></a>
    </div>
</aside>

<div class="main-content">
    <div class="topbar">
        <div><h1>Create New Incident</h1><p>@dept — Report a new civic incident</p></div>
        <div class="user-profile"><i class="fas fa-user-circle"></i> @operatorName</div>
    </div>

    <div class="content-area">
        <a href="/Operator/Incidents" style="display:inline-flex;align-items:center;gap:8px;color:#94A3B8;text-decoration:none;margin-bottom:24px;"><i class="fas fa-arrow-left"></i> Back to Incidents</a>

        <div class="card">
            <div class="card-title"><i class="fas fa-plus-circle"></i> Incident Details</div>
            <form method="post" action="/Operator/CreateIncident">
                <div style="background:rgba(59,130,246,0.1);border:1px solid rgba(59,130,246,0.2);border-radius:10px;padding:12px 16px;margin-bottom:24px;color:#3B82F6;">
                    <i class="fas fa-building"></i> This incident will be assigned to: <strong>@dept</strong>
                </div>
                <div class="form-grid">
                    <div class="form-group full">
                        <label>Title <span style="color:#EF4444;">*</span></label>
                        <input type="text" name="Title" placeholder="e.g. Market Fire in Gulshan" required />
                    </div>
                    <div class="form-group full">
                        <label>Description <span style="color:#EF4444;">*</span></label>
                        <textarea name="Description" placeholder="Describe the incident in detail..." required></textarea>
                    </div>
                    <div class="form-group full">
                        <label>Location <span style="color:#EF4444;">*</span></label>
                        <input type="text" name="Location" placeholder="e.g. Gulshan Chowrangi, Near KFC, Karachi" required />
                    </div>
                    <div class="form-group">
                        <label>Severity <span style="color:#EF4444;">*</span></label>
                        <select name="Severity" required>
                            <option value="Low">Low</option>
                            <option value="Medium" selected>Medium</option>
                            <option value="High">High</option>
                            <option value="Critical">Critical</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Latitude (Optional)</label>
                        <input type="text" name="Latitude" placeholder="e.g. 24.8607" />
                    </div>
                    <div class="form-group">
                        <label>Longitude (Optional)</label>
                        <input type="text" name="Longitude" placeholder="e.g. 67.0011" />
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-submit"><i class="fas fa-save"></i> Create Incident</button>
                    <a href="/Operator/Incidents" class="btn-cancel"><i class="fas fa-times"></i> Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

</body>
</html>