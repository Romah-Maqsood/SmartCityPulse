@model SmartCityPulse.Models.OperatorDashboardViewModel
@{
    ViewData["Title"] = "Operator Dashboard";
    Layout = null;
    string operatorName = ViewBag.OperatorName ?? "";
    string dept = ViewBag.Department ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - @dept Department</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/site.css" />
    <style>
        .main-content {
        margin-left: 280px;
        flex: 1;
        }
        
        @@media (max-width: 768px) {
        .main-content {
        margin-left: 80px;
        }
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">🚨</div>
            <h2>SMART CIVIC</h2>
            <span>ALERT SYSTEM</span>
        </div>
        <nav class="sidebar-nav">
            <a href="/Operator/Dashboard" class="nav-item active">
                <i class="fas fa-tachometer-alt"></i> <span>Dashboard</span>
            </a>
            <a href="/Operator/Incidents" class="nav-item">
                <i class="fas fa-list-alt"></i> <span>Incidents</span>
            </a>
            <a href="/Operator/CreateIncident" class="nav-item">
                <i class="fas fa-plus-circle"></i> <span>Create Incident</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <div class="dept-badge">
                <i class="fas fa-building"></i> @dept Department
            </div>
            <a href="/Account/Logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i> <span>Logout</span>
            </a>
        </div>
    </aside>

    <div class="main-content">
        <div class="topbar">
            <div class="welcome-text">
                <h1>Welcome back, <span>@operatorName</span>! 👋</h1>
                <p>@dept Department Dashboard — Real-time incident analytics</p>
            </div>
            <div class="user-profile">
                <i class="fas fa-user-circle"></i> @operatorName
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-header">
                    <span>New Today</span>
                    <div class="stat-icon"><i class="fas fa-fire"></i></div>
                </div>
                <h2>@ViewBag.NewToday</h2>
                <p>New incidents reported</p>
            </div>
            <div class="stat-card">
                <div class="stat-header">
                    <span>In Progress</span>
                    <div class="stat-icon"><i class="fas fa-spinner"></i></div>
                </div>
                <h2>@ViewBag.InProgress</h2>
                <p>Being handled</p>
            </div>
            <div class="stat-card">
                <div class="stat-header">
                    <span>Resolved</span>
                    <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                </div>
                <h2>@ViewBag.Resolved</h2>
                <p>Successfully resolved</p>
            </div>
            <div class="stat-card">
                <div class="stat-header">
                    <span>Total</span>
                    <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
                </div>
                <h2>@ViewBag.Total</h2>
                <p>Total incidents</p>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="charts-section">
            <div class="chart-card">
                <div class="chart-title">
                    <i class="fas fa-chart-bar"></i> Last 7 Days Trend
                </div>
                <canvas id="trendChart"></canvas>
            </div>
            <div class="chart-card">
                <div class="chart-title">
                    <i class="fas fa-chart-pie"></i> Severity Distribution
                </div>
                <canvas id="severityChart"></canvas>
            </div>
            <div class="chart-card">
                <div class="chart-title">
                    <i class="fas fa-chart-donut"></i> Status Distribution
                </div>
                <canvas id="statusChart"></canvas>
            </div>
            <div class="chart-card">
                <div class="chart-title">
                    <i class="fas fa-chart-line"></i> Monthly Trend
                </div>
                <canvas id="monthlyChart"></canvas>
            </div>
        </div>

        <!-- Recent Incidents -->
        <div class="incidents-section">
            <div class="section-header">
                <div class="section-title">
                    <i class="fas fa-exclamation-triangle"></i>
                    Recent Incidents - @dept Department
                </div>
                <a href="/Operator/CreateIncident" class="btn-primary">
                    <i class="fas fa-plus"></i> Report Incident
                </a>
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Location</th>
                            <th>Severity</th>
                            <th>Status</th>
                            <th>Reported</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.RecentIncidents.Any())
                        {
                            <tr>
                                <td colspan="6">
                                    <div class="empty-state">
                                        <i class="fas fa-inbox"></i>
                                        No incidents reported yet
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var incident in Model.RecentIncidents)
                            {
                                <tr>
                                    <td><strong>@incident.Title</strong></td>
                                    <td><i class="fas fa-map-marker-alt" style="color:#3B82F6;margin-right:6px;"></i>@incident.Location</td>
                                    <td><span class="badge badge-@incident.Severity.ToLower()">@incident.Severity</span></td>
                                    <td>
                                        @{
                                            var statusClass = incident.Status == "Open" ? "status-open"
                                                : incident.Status == "In Progress" ? "status-inprogress"
                                                : "status-resolved";
                                        }
                                        <span class="@statusClass">@incident.Status</span>
                                    </td>
                                    <td style="color:#94A3B8;">@incident.ReportedAt.ToString("dd MMM, hh:mm tt")</td>
                                    <td>
                                        <a href="/Operator/IncidentDetail/@incident.Id" class="btn-detail">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Last 7 Days Trend Chart
        const trendCtx = document.getElementById('trendChart').getContext('2d');
        new Chart(trendCtx, {
        type: 'line',
        data: {
        labels: ['6 days ago', '5 days ago', '4 days ago', '3 days ago', '2 days ago', 'Yesterday', 'Today'],
        datasets: [{
        label: 'Incidents',
        data: @Html.Raw(ViewBag.Last7Days ?? "[0,0,0,0,0,0,0]"),
        borderColor: '#3B82F6',
        backgroundColor: 'rgba(59, 130, 246, 0.1)',
        tension: 0.4,
        fill: true
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: { labels: { color: '#FFFFFF' } }
        },
        scales: {
        y: { ticks: { color: '#94A3B8' }, grid: { color: '#334155' } },
        x: { ticks: { color: '#94A3B8' }, grid: { color: '#334155' } }
        }
        }
        });

        // Severity Distribution Chart
        const severityCtx = document.getElementById('severityChart').getContext('2d');
        new Chart(severityCtx, {
        type: 'doughnut',
        data: {
        labels: ['Critical', 'High', 'Medium', 'Low'],
        datasets: [{
        data: [@ViewBag.CriticalCount, @ViewBag.HighCount, @ViewBag.MediumCount, @ViewBag.LowCount],
        backgroundColor: ['#EF4444', '#F59E0B', '#EAB308', '#22C55E'],
        borderWidth: 0
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: { labels: { color: '#FFFFFF' } }
        }
        }
        });

        // Status Distribution Chart
        const statusCtx = document.getElementById('statusChart').getContext('2d');
        new Chart(statusCtx, {
        type: 'pie',
        data: {
        labels: ['Open', 'In Progress', 'Resolved'],
        datasets: [{
        data: [@ViewBag.OpenCount, @ViewBag.InProgressCount, @ViewBag.ResolvedCount],
        backgroundColor: ['#3B82F6', '#F59E0B', '#22C55E'],
        borderWidth: 0
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: { labels: { color: '#FFFFFF' } }
        }
        }
        });

        // Monthly Trend Chart
        const monthlyCtx = document.getElementById('monthlyChart').getContext('2d');
        const monthlyData = @Html.Raw(ViewBag.MonthlyData ?? "{}");
        new Chart(monthlyCtx, {
        type: 'bar',
        data: {
        labels: Object.keys(monthlyData),
        datasets: [{
        label: 'Incidents',
        data: Object.values(monthlyData),
        backgroundColor: '#3B82F6',
        borderRadius: 8
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: { labels: { color: '#FFFFFF' } }
        },
        scales: {
        y: { ticks: { color: '#94A3B8' }, grid: { color: '#334155' } },
        x: { ticks: { color: '#94A3B8' }, grid: { color: '#334155' } }
        }
        }
        });
    </script>

</body>
</html>