@model SmartCityPulse.Models.Incident
@{
    ViewData["Title"] = "Incident Detail";
    Layout = null;
    string operatorName = ViewBag.OperatorName ?? "";
    string dept = ViewBag.Department ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Incident Detail</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/site.css" />
    <style>
        .main-content { margin-left: 280px; flex: 1; }
        .content-area { padding: 32px; }
        .detail-grid { display: grid; grid-template-columns: 1fr 380px; gap: 24px; }
        .card { background: #1E293B; border: 1px solid #334155; border-radius: 16px; padding: 28px; margin-bottom: 20px; }
        .card-title { font-size: 16px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        .card-title i { color: #3B82F6; }
        .incident-title { font-size: 22px; font-weight: 700; margin-bottom: 8px; }
        .incident-id { font-size: 13px; color: #94A3B8; margin-bottom: 20px; }
        .detail-row { display: flex; align-items: flex-start; gap: 14px; padding: 14px 0; border-bottom: 1px solid #334155; }
        .detail-icon { width: 36px; height: 36px; background: #0F172A; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #3B82F6; }
        .detail-label { font-size: 11px; color: #94A3B8; margin-bottom: 4px; text-transform: uppercase; }
        .detail-value { font-size: 14px; font-weight: 500; }
        .btn-save { background: #3B82F6; color: #fff; border: none; padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; width: 100%; }
        .btn-save:hover { background: #2563EB; }
        .comment-item { padding: 14px 0; border-bottom: 1px solid #334155; }
        .comment-author { font-size: 13px; font-weight: 600; color: #3B82F6; }
        .comment-time { font-size: 11px; color: #94A3B8; }
        @@media (max-width: 768px) { .main-content { margin-left: 80px; } .detail-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-brand"><div class="brand-icon">🚨</div><h2>SMART CIVIC</h2><span>ALERT SYSTEM</span></div>
    <nav class="sidebar-nav">
        <a href="/Operator/Dashboard" class="nav-item"><i class="fas fa-tachometer-alt"></i> <span>Dashboard</span></a>
        <a href="/Operator/Incidents" class="nav-item active"><i class="fas fa-list-alt"></i> <span>Incidents</span></a>
        <a href="/Operator/CreateIncident" class="nav-item"><i class="fas fa-plus-circle"></i> <span>Create Incident</span></a>
    </nav>
    <div class="sidebar-footer">
        <div class="dept-badge"><i class="fas fa-building"></i> @dept Department</div>
        <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> <span>Logout</span></a>
    </div>
</aside>

<div class="main-content">
    <div class="topbar">
        <div><h1>Incident Details</h1><p>@dept — View and manage incident</p></div>
        <div class="user-profile"><i class="fas fa-user-circle"></i> @operatorName</div>
    </div>

    <div class="content-area">
        @if (TempData["Success"] != null)
        {
            <div style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);color:#22C55E;padding:12px 20px;border-radius:10px;margin-bottom:20px;"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
        }

        <a href="/Operator/Incidents" style="display:inline-flex;align-items:center;gap:8px;color:#94A3B8;text-decoration:none;margin-bottom:24px;"><i class="fas fa-arrow-left"></i> Back to Incidents</a>

        <div class="detail-grid">
            <div>
                <div class="card">
                    <div class="incident-title">@Model.Title</div>
                    <div class="incident-id">Incident ID: @Model.Id</div>
                    <div class="detail-row"><div class="detail-icon"><i class="fas fa-align-left"></i></div><div><div class="detail-label">Description</div><div class="detail-value">@Model.Description</div></div></div>
                    <div class="detail-row"><div class="detail-icon"><i class="fas fa-map-marker-alt"></i></div><div><div class="detail-label">Location</div><div class="detail-value">@Model.Location</div></div></div>
                    <div class="detail-row"><div class="detail-icon"><i class="fas fa-exclamation-triangle"></i></div><div><div class="detail-label">Severity</div><div class="detail-value"><span class="badge badge-@Model.Severity.ToLower()">@Model.Severity</span></div></div></div>
                    <div class="detail-row"><div class="detail-icon"><i class="fas fa-traffic-light"></i></div><div><div class="detail-label">Status</div><div class="detail-value"><span class="status-@Model.Status.ToLower().Replace(" ", "")">@Model.Status</span></div></div></div>
                    <div class="detail-row"><div class="detail-icon"><i class="fas fa-building"></i></div><div><div class="detail-label">Department</div><div class="detail-value">@Model.Department</div></div></div>
                    <div class="detail-row"><div class="detail-icon"><i class="fas fa-user"></i></div><div><div class="detail-label">Reported By</div><div class="detail-value">@Model.ReportedBy</div></div></div>
                    <div class="detail-row"><div class="detail-icon"><i class="fas fa-clock"></i></div><div><div class="detail-label">Reported At</div><div class="detail-value">@Model.ReportedAt.ToString("dd MMM yyyy, hh:mm tt")</div></div></div>
                </div>

                <div class="card">
                    <div class="card-title"><i class="fas fa-comments"></i> Comments & Timeline</div>
                    @if (!Model.Comments.Any())
                    {
                        <p style="color:#94A3B8;">No comments yet.</p>
                    }
                    else
                    {
                        @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                        {
                            <div class="comment-item">
                                <div class="comment-header" style="display:flex;justify-content:space-between;margin-bottom:6px;">
                                    <span class="comment-author"><i class="fas fa-user-circle"></i> @comment.Author</span>
                                    <span class="comment-time">@comment.CreatedAt.ToString("hh:mm tt, dd MMM")</span>
                                </div>
                                <div class="comment-text">@comment.Text</div>
                            </div>
                        }
                    }
                    <div style="margin-top:16px;padding-top:16px;border-top:1px solid #334155;">
                        <form method="post" action="/Operator/AddComment">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="form-group" style="margin-bottom:12px;">
                                <textarea name="commentText" placeholder="Write your update here..." required style="width:100%;background:#0F172A;border:1px solid #334155;color:#fff;padding:12px;border-radius:10px;"></textarea>
                            </div>
                            <button type="submit" class="btn-save" style="background:#334155;"><i class="fas fa-paper-plane"></i> Add Comment</button>
                        </form>
                    </div>
                </div>
            </div>

            <div>
                <div class="card">
                    <div class="card-title"><i class="fas fa-edit"></i> Update Incident</div>
                    <form method="post" action="/Operator/UpdateStatus">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="form-group" style="margin-bottom:16px;">
                            <label style="display:block;font-size:13px;color:#94A3B8;margin-bottom:8px;">Update Status</label>
                            <select name="status" style="width:100%;background:#0F172A;border:1px solid #334155;color:#fff;padding:12px;border-radius:10px;">
                                <option value="Open" selected="@(Model.Status == "Open")">Open</option>
                                <option value="In Progress" selected="@(Model.Status == "In Progress")">In Progress</option>
                                <option value="Resolved" selected="@(Model.Status == "Resolved")">Resolved</option>
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom:16px;">
                            <label style="display:block;font-size:13px;color:#94A3B8;margin-bottom:8px;">Add Comment (Optional)</label>
                            <textarea name="comment" placeholder="Describe the update..." style="width:100%;background:#0F172A;border:1px solid #334155;color:#fff;padding:12px;border-radius:10px;min-height:80px;"></textarea>
                        </div>
                        <button type="submit" class="btn-save"><i class="fas fa-save"></i> Save Changes</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>